# Google Gemini API（無料・[Google AI Studio](https://aistudio.google.com/apikey) で発行）
GEMINI_API_KEY=your_gemini_api_key

# 任意: モデル名（未設定時は gemini-2.5-flash）
# GEMINI_MODEL=gemini-2.5-flash

# VOICEVOX Web API（クラウド利用時）
VOICEVOX_BASE_URL=https://your-voicevox-api.example.com
VOICEVOX_API_KEY=your_voicevox_api_key
